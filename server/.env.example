MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/bandlab?retryWrites=true&w=majority
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Supabase — get from https://app.supabase.com → Project Settings → API
# Use the service_role key (NOT the anon key) — never expose this to the browser
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
